# Use official Python image
FROM python:3.10

# Set working directory inside container
WORKDIR /app

# Copy all project files into container
COPY . .

# Install Rasa and other dependencies
RUN pip install --no-cache-dir -r requirements.txt

# Expose the port Render uses (must be 8080)
EXPOSE 8080

# (Optional) Train model if not yet trained
RUN rasa train

# Start Rasa server with API enabled and allow any frontend connection
CMD ["rasa", "run", "--enable-api", "--cors", "*", "--port", "8080"]
