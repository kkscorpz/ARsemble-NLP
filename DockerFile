# Use official Python image
FROM python:3.10

# Set working directory
WORKDIR /app

# Copy all files
COPY . .

# Install dependencies
RUN pip install -r requirements.txt

# Expose Rasa ports
EXPOSE 5005

# Train model (optional if you already have one)
RUN rasa train

# Start the Rasa server
CMD ["rasa", "run",]()
